generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  INSPECTOR
  AUDITOR
}

enum InspectionType {
  ARRIVAL
  DEPARTURE
  PERIODIC
}

enum InspectionStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  CLARIFICATION
}

enum PhotoAngle {
  FRONT
  BACK
  LEFT
  RIGHT
  INTERIOR
  SERIAL
  OTHER
}

enum ProcessingStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum AuditAction {
  LOGIN
  LOGOUT
  CREATE
  UPDATE
  DELETE
  SUBMIT
  VERIFY
  REJECT
  CLARIFY
  EXPORT
  OCR_CORRECT
  WEBHOOK_DISPATCH
}

enum WebhookDeliveryStatus {
  PENDING
  SUCCESS
  FAILED
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  fullName     String    @map("full_name") @db.VarChar(150)
  email        String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  role         UserRole
  phone        String?   @db.VarChar(30)
  profileUrl   String?   @map("profile_url")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  lastLoginAt  DateTime? @map("last_login_at")

  refreshTokens RefreshToken[]
  inspections   InspectionSession[] @relation("InspectorSessions")
  verified      InspectionSession[] @relation("VerifiedSessions")
  auditLogs     AuditLog[]

  @@map("users")
}

model RefreshToken {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  tokenHash    String   @map("token_hash")
  expiresAt    DateTime @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  replacedById String?  @map("replaced_by_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model InspectionSession {
  id             String           @id @default(uuid()) @db.Uuid
  containerId    String           @map("container_id") @db.VarChar(20)
  inspectorId    String           @map("inspector_id") @db.Uuid
  inspectionType InspectionType   @map("inspection_type")
  locationName   String           @map("location_name") @db.VarChar(255)
  latitude       Decimal?         @db.Decimal(9, 6)
  longitude      Decimal?         @db.Decimal(9, 6)
  status         InspectionStatus @default(DRAFT)
  notes          String?
  adminComment   String?          @map("admin_comment")
  verifiedById   String?          @map("verified_by_id") @db.Uuid
  verifiedAt     DateTime?        @map("verified_at")
  submittedAt    DateTime?        @map("submitted_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  inspector  User              @relation("InspectorSessions", fields: [inspectorId], references: [id])
  verifiedBy User?             @relation("VerifiedSessions", fields: [verifiedById], references: [id])
  photos     InspectionPhoto[]
  auditLogs  AuditLog[]

  @@index([containerId])
  @@index([status])
  @@index([inspectorId])
  @@index([createdAt])
  @@index([locationName])
  @@map("inspection_sessions")
}

model InspectionPhoto {
  id            String     @id @default(uuid()) @db.Uuid
  sessionId     String     @map("session_id") @db.Uuid
  storageKey    String     @map("storage_key")
  thumbnailKey  String?    @map("thumbnail_key")
  photoAngle    PhotoAngle @map("photo_angle")
  mimeType      String     @map("mime_type") @db.VarChar(100)
  fileSizeBytes Int        @map("file_size_bytes")
  width         Int?
  height        Int?
  resolution    String?    @db.VarChar(20)
  checksumSha256 String?   @map("checksum_sha256") @db.VarChar(64)
  exifTimestamp DateTime?  @map("exif_timestamp")
  deviceInfo    String?    @map("device_info") @db.VarChar(255)
  latitude      Decimal?   @db.Decimal(9, 6)
  longitude     Decimal?   @db.Decimal(9, 6)
  uploadedAt    DateTime   @default(now()) @map("uploaded_at")

  session  InspectionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  ocrResult OcrResult?
  cvResult  CvResult?

  @@index([sessionId])
  @@index([photoAngle])
  @@map("inspection_photos")
}

model OcrResult {
  id              String           @id @default(uuid()) @db.Uuid
  photoId         String           @unique @map("photo_id") @db.Uuid
  status          ProcessingStatus @default(QUEUED)
  detectedSerial  String?          @map("detected_serial") @db.VarChar(20)
  confirmedSerial String?          @map("confirmed_serial") @db.VarChar(20)
  confidenceScore Float?           @map("confidence_score")
  boundingBox     Json?            @map("bounding_box")
  rawResult       Json?            @map("raw_result")
  isCorrected     Boolean          @default(false) @map("is_corrected")
  errorMessage    String?          @map("error_message")
  processedAt     DateTime?        @map("processed_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  photo InspectionPhoto @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("ocr_results")
}

model CvResult {
  id           String           @id @default(uuid()) @db.Uuid
  photoId      String           @unique @map("photo_id") @db.Uuid
  status       ProcessingStatus @default(QUEUED)
  damageLabels Json?            @map("damage_labels")
  rawResult    Json?            @map("raw_result")
  errorMessage String?          @map("error_message")
  processedAt  DateTime?        @map("processed_at")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  photo InspectionPhoto @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("cv_results")
}

model WebhookEndpoint {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(120)
  url       String
  secret    String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  deliveries WebhookDelivery[]

  @@index([isActive])
  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id          String                @id @default(uuid()) @db.Uuid
  endpointId  String                @map("endpoint_id") @db.Uuid
  eventType   String                @map("event_type") @db.VarChar(100)
  payload     Json
  status      WebhookDeliveryStatus @default(PENDING)
  statusCode  Int?                  @map("status_code")
  error       String?
  attempts    Int                   @default(0)
  nextRetryAt DateTime?             @map("next_retry_at")
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId])
  @@index([status])
  @@index([nextRetryAt])
  @@map("webhook_deliveries")
}

model AuditLog {
  id         String      @id @default(uuid()) @db.Uuid
  userId     String?     @map("user_id") @db.Uuid
  sessionId  String?     @map("session_id") @db.Uuid
  action     AuditAction
  entityType String      @map("entity_type") @db.VarChar(50)
  entityId   String?     @map("entity_id") @db.Uuid
  metadata   Json?
  ipAddress  String?     @map("ip_address") @db.Inet
  userAgent  String?     @map("user_agent")
  timestamp  DateTime    @default(now())

  user    User?              @relation(fields: [userId], references: [id])
  session InspectionSession? @relation(fields: [sessionId], references: [id])

  @@index([userId, timestamp])
  @@index([sessionId])
  @@index([action])
  @@index([timestamp])
  @@map("audit_logs")
}
